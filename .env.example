# ============================================================================
# Gig Platform — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file!
# ============================================================================

# --- Contract Deployment ---
# Private key of the deployment account (must have MON for gas)
PRIVATE_KEY=0x...

# RPC endpoint for Monad testnet
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Admin address for TaskEscrow (can adminCancel tasks, two-step transfer)
ADMIN_ADDRESS=0x...

# --- Deployed Contract Addresses (filled after deployment) ---
WORKER_REGISTRY_ADDRESS=0x...
TASK_ESCROW_ADDRESS=0x...

# --- Block Explorer Verification ---
# API key for Monad block explorer (MonadVision / MonadScan)
ETHERSCAN_API_KEY=...
MONAD_EXPLORER_API_URL=https://testnet.monadexplorer.com/api

# --- Frontend (public, prefixed with NEXT_PUBLIC_) ---
NEXT_PUBLIC_TASK_ESCROW_ADDRESS=0x...
NEXT_PUBLIC_WORKER_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_CHAIN_ID=10143

# --- IPFS / Pinning ---
# nft.storage API key (legacy pinning provider)
NFT_STORAGE_API_KEY=...

# Pinata API keys (production pinning provider)
PINATA_API_KEY=...
PINATA_SECRET_API_KEY=...

# Which pinning provider to use: "pinata" or "nftstorage"
NEXT_PUBLIC_IPFS_PROVIDER=pinata
